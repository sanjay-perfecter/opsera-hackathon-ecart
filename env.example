# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/metayb-ecommerce

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_EXPIRE=1h
JWT_REFRESH_EXPIRE=7d

# Encryption Key for Token Storage (32 characters)
ENCRYPTION_KEY=your_32_character_encryption_key_

# Internal service-to-service auth (shared secret)
INTERNAL_SERVICE_KEY=change_me_internal_service_key

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# Service Ports
GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5001
USER_SERVICE_PORT=5002
PRODUCT_SERVICE_PORT=5003
CART_ORDER_SERVICE_PORT=5004
PAYMENT_SERVICE_PORT=5005

# Service URLs (for gateway)
AUTH_SERVICE_URL=http://localhost:5001
USER_SERVICE_URL=http://localhost:5002
PRODUCT_SERVICE_URL=http://localhost:5003
CART_ORDER_SERVICE_URL=http://localhost:5004
PAYMENT_SERVICE_URL=http://localhost:5005

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Node Environment
NODE_ENV=development
